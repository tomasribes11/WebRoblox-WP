# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=webroblox_wp
MYSQL_USER=wpuser
MYSQL_PASSWORD=wppassword

# ─── WordPress DB connection (leído por la imagen oficial wordpress:php8.2-fpm) ─
WORDPRESS_DB_HOST=mysql:3306
WORDPRESS_DB_NAME=webroblox_wp
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=wppassword
WORDPRESS_TABLE_PREFIX=wp_

# ─── WordPress Site (usado por scripts/setup-wp.sh) ──────────────────────────
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_SITE_TITLE=Mundo Roblox
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin123
WP_ADMIN_EMAIL=admin@example.com

# ─── Debug (cambiar a false en producción) ────────────────────────────────────
WORDPRESS_DEBUG=1
